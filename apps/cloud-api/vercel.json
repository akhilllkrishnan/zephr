{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/[[...route]].ts": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/health",
      "destination": "/api/health"
    },
    {
      "source": "/v1/(.*)",
      "destination": "/api/v1/$1"
    }
  ]
}
