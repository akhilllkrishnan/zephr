# Lemon Squeezy integration
LEMON_SQUEEZY_API_KEY=lsk_live_xxxxxxxxxxxxxxxxxxxxxxxx
LEMON_SQUEEZY_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx
ZEPHR_REQUIRE_WEBHOOK_SIGNATURE=true

# Supabase (optional but recommended for production persistence)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Variant ID -> plan mapping (set to your Lemon Squeezy variant IDs)
ZEPHR_LS_VARIANT_INDIVIDUAL=
ZEPHR_LS_VARIANT_STARTUP=
ZEPHR_LS_VARIANT_ENTERPRISE=

# Plan checkout links (used by docs and public plan discovery endpoint)
ZEPHR_LS_CHECKOUT_INDIVIDUAL=
ZEPHR_LS_CHECKOUT_STARTUP=
ZEPHR_LS_CHECKOUT_ENTERPRISE=

# Zephr API auth keys (comma-separated)
ZEPHR_API_KEYS=dev_local_key

# Optional local fallback license keys
# Format: key:plan:expiresAt
# plan = individual|startup|enterprise|pro|team (comma-separated records)
ZEPHR_LICENSE_KEYS=zephr-pro-demo-2026:pro:2027-12-31T23:59:59.000Z
ZEPHR_REVOKED_LICENSE_KEYS=
ZEPHR_ALLOW_LOCAL_LICENSE_FALLBACK=true
ZEPHR_LICENSE_STORE_PATH=./apps/cloud-api/data/license-store.json

# Optional server config
PORT=8787
ZEPHR_CORS_ORIGIN=*
ZEPHR_AUDIT_LOG=
