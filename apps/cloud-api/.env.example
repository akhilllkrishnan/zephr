# Lemon Squeezy integration
LEMON_SQUEEZY_API_KEY=lsk_live_xxxxxxxxxxxxxxxxxxxxxxxx
LEMON_SQUEEZY_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx
ZEPHYR_REQUIRE_WEBHOOK_SIGNATURE=true

# Supabase (optional but recommended for production persistence)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Variant ID -> plan mapping (set to your Lemon Squeezy variant IDs)
ZEPHYR_LS_VARIANT_INDIVIDUAL=
ZEPHYR_LS_VARIANT_STARTUP=
ZEPHYR_LS_VARIANT_ENTERPRISE=

# Plan checkout links (used by docs and public plan discovery endpoint)
ZEPHYR_LS_CHECKOUT_INDIVIDUAL=
ZEPHYR_LS_CHECKOUT_STARTUP=
ZEPHYR_LS_CHECKOUT_ENTERPRISE=

# Zephyr API auth keys (comma-separated)
ZEPHYR_API_KEYS=dev_local_key

# Optional local fallback license keys
# Format: key:plan:expiresAt
# plan = individual|startup|enterprise|pro|team (comma-separated records)
ZEPHYR_LICENSE_KEYS=zephyr-pro-demo-2026:pro:2027-12-31T23:59:59.000Z
ZEPHYR_REVOKED_LICENSE_KEYS=
ZEPHYR_ALLOW_LOCAL_LICENSE_FALLBACK=true
ZEPHYR_LICENSE_STORE_PATH=./apps/cloud-api/data/license-store.json

# Optional server config
PORT=8787
ZEPHYR_CORS_ORIGIN=*
ZEPHYR_AUDIT_LOG=
