{
  "name": "@zephrui/docs-playground",
  "version": "0.1.0",
  "private": true,
  "description": "Zephr docs playground with live prop and style-pack controls",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview --port 4173",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit && node ../../scripts/check-docs-theme-colors.mjs",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@vercel/speed-insights": "^1.3.1",
    "@zephrui/ai-registry": "workspace:*",
    "@zephrui/avatars": "workspace:*",
    "@zephrui/cloud-sdk": "workspace:*",
    "@zephrui/core": "workspace:*",
    "@zephrui/icons-material": "workspace:*",
    "@zephrui/logos": "workspace:*",
    "@zephrui/ui-react": "workspace:*",
    "fuse.js": "^7.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.2",
    "jsdom": "^29.0.1",
    "vite": "^6.0.11",
    "vitest": "^4.1.2"
  }
}
