{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zephr.local/schemas/registry.schema.json",
  "title": "Zephyr Component Registry",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "id",
      "name",
      "category",
      "propsSchema",
      "a11yNotes",
      "dependencies",
      "stylePackSupport",
      "aiHints"
    ],
    "properties": {
      "id": { "type": "string" },
      "name": { "type": "string" },
      "category": {
        "type": "string",
        "enum": ["foundation", "atom", "molecule", "organism", "template"]
      },
      "tier": {
        "type": "string",
        "enum": ["free", "pro"]
      },
      "description": { "type": "string" },
      "propsSchema": {
        "type": "object",
        "additionalProperties": {
          "oneOf": [
            { "type": "string" },
            {
              "type": "array",
              "items": { "type": ["string", "number", "boolean"] }
            },
            {
              "type": "object",
              "required": ["type"],
              "properties": {
                "type": {
                  "oneOf": [
                    { "type": "string" },
                    {
                      "type": "array",
                      "items": { "type": ["string", "number", "boolean"] }
                    }
                  ]
                },
                "description": { "type": "string" },
                "required": { "type": "boolean" },
                "default": {},
                "deprecated": { "type": "boolean" },
                "values": {
                  "type": "array",
                  "items": { "type": ["string", "number", "boolean"] }
                }
              },
              "additionalProperties": false
            }
          ]
        }
      },
      "a11yNotes": {
        "type": "array",
        "items": { "type": "string" }
      },
      "dependencies": {
        "type": "array",
        "items": { "type": "string" }
      },
      "stylePackSupport": {
        "type": "array",
        "items": { "type": "string" }
      },
      "aiHints": {
        "type": "array",
        "items": { "type": "string" }
      },
      "usageExamples": {
        "type": "array",
        "items": { "type": "string" }
      }
    },
    "additionalProperties": false
  }
}
