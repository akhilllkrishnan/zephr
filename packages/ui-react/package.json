    "@zephyr/avatars": "workspace:*",
    "@zephyr/logos": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0"
