{
  "name": "@zephrui/ui-react",
  "version": "0.1.0",
  "description": "React-first Zephr component library",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./tokens.css": "./dist/tokens.css",
    "./themes/*": "./dist/themes/*"
  },
  "files": [
    "dist",
    "postinstall.mjs"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node ./scripts/copy-theme-assets.mjs && node ./scripts/copy-postinstall.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "tsc -p tsconfig.json --noEmit",
    "postinstall": "node postinstall.mjs || true"
  },
  "dependencies": {
    "@zephrui/core": "workspace:*",
    "@zephrui/icons-material": "workspace:*",
    "@zephrui/avatars": "workspace:*",
    "@zephrui/logos": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0"
  }
}
