{
  "name": "zephyr-monorepo",
  "private": true,
  "version": "0.1.0",
  "description": "Zephyr v1: AI-native design system + cloud assets platform",
  "license": "MIT",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "figma:export": "node scripts/export-figma-tokens.js",
    "test:unit": "vitest run",
    "docs:dev": "pnpm --filter @zephyr/docs-playground dev",
    "docs:build": "pnpm --filter @zephyr/docs-playground build",
    "release:check": "bash scripts/release-check.sh",
    "release:dry": "bash scripts/publish.sh",
    "release": "bash scripts/publish.sh --no-dry-run",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "pnpm build && changeset publish",
    "ui:smoke:agent": "bash scripts/ui-agent-smoke.sh",
    "storybook": "CI=1 storybook dev -p 6006",
    "storybook:build": "CI=1 storybook build"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@storybook/addon-a11y": "8.6.17",
    "@storybook/addon-docs": "8.6.17",
    "@storybook/addon-essentials": "8.6.17",
    "@storybook/addon-links": "8.6.17",
    "@storybook/react": "8.6.17",
    "@storybook/react-vite": "8.6.17",
    "@types/node": "^22.10.1",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "color-convert": "^2.0.1",
    "color-name": "^1.1.4",
    "doctrine": "^3.0.0",
    "esutils": "^2.0.3",
    "picomatch": "^4.0.3",
    "pnpm": "^10.6.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "storybook": "8.6.17",
    "turbo": "^2.4.4",
    "typescript": "^5.7.3",
    "vite": "^6.4.1",
    "vitest": "^2.1.8"
  }
}