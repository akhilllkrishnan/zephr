{
  "name": "zephr-monorepo",
  "private": true,
  "version": "0.1.0",
  "description": "Zephr v1: AI-native design system + cloud assets platform",
  "license": "MIT",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "figma:export": "node scripts/export-figma-tokens.js",
    "test:unit": "vitest run",
    "docs:dev": "pnpm --filter @zephrui/docs-playground dev",
    "docs:build": "pnpm --filter @zephrui/docs-playground build",
    "release:check": "bash scripts/release-check.sh",
    "release:dry": "bash scripts/publish.sh",
    "release": "bash scripts/publish.sh --no-dry-run",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "pnpm build && changeset publish",
    "ui:smoke:agent": "bash scripts/ui-agent-smoke.sh"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@types/node": "^22.10.1",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "color-convert": "^2.0.1",
    "color-name": "^1.1.4",
    "doctrine": "^3.0.0",
    "esutils": "^2.0.3",
    "picomatch": "^4.0.3",
    "pnpm": "^10.6.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "turbo": "^2.4.4",
    "typescript": "^5.7.3",
    "vite": "^6.4.1",
    "vitest": "^2.1.8"
  }
}
